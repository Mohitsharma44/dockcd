# dockcd environment variables
# Copy to /etc/dockcd/dockcd.env and adjust as needed.

# Host name — determines which stacks this agent manages.
# Falls back to os.Hostname() if unset.
# DOCKCD_HOST=server01

# Local path where the git repo is cloned.
# DOCKCD_REPO_DIR=/opt/dockcd/repo

# Port for the /metrics and /healthz HTTP server.
# DOCKCD_METRICS_PORT=9092

# How often to poll git for changes.
# DOCKCD_POLL_INTERVAL=30s

# Deploy all stacks on first run (set to "true" to enable).
# DOCKCD_INITIAL_SYNC=false

# OTLP gRPC endpoint for trace export (e.g. Alloy, Tempo).
# Leave unset to disable tracing (zero overhead).
# DOCKCD_OTEL_ENDPOINT=localhost:4317
